{
    "name": "Wingman/Helix",
    "version": "1.0.0",
    "type": "library",
    "description": "A PHP reflection and contract enforcement library for the Wingman framework, providing a rich API for inspecting class members, methods, properties, parameters, and verifying type contracts at runtime.",
    "authors": [
        {
            "name": "Angel Politis",
            "email": "info@angelpolitis.com"
        }
    ],
    "license": "MPL-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/angelpolitis/Wingman-Helix.git"
    },
    "homepage": "https://github.com/angelpolitis/Wingman-Helix",
    "php": ">=8.1",
    "dependencies": [
        {
            "package": "Wingman/Argus",
            "version": ">=1.0",
            "optional": true
        }
    ],
    "autoload": {
        "psr-4": {
            "Wingman.Helix.": "src/"
        }
    }
}